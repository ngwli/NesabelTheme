<script>
(function () {
  var COOKIE_NAME = 'nesabel_branch';
  var BRANCHES = [
    'nesabelbustoswholesale','nesabelbustos',
    'nesabelpateroswholesale','nesabelpateros',
    'nesabelsanrafaelwholesale','nesabelsanrafael',
    'chronosmartwholesale','chronosmart'
  ];

  function setCookie(name, value, days) {
    var expires = new Date(Date.now() + days * 864e5).toUTCString();
    document.cookie = name + '=' + encodeURIComponent(value) + '; expires=' + expires + '; path=/';
  }

  function getCookie(name) {
    var match = document.cookie.match(new RegExp('(?:^|;\\s*)' + name + '=([^;]+)'));
    return match ? decodeURIComponent(match[1]) : null;
  }

  // 1. Check ?view= param first
  var view = (new URLSearchParams(window.location.search).get('view') || '').toLowerCase();

  // 2. If valid branch in URL, save it to cookie
  if (view && BRANCHES.indexOf(view) !== -1) {
    setCookie(COOKIE_NAME, view, 30);
  } else {
    // 3. No param — fall back to cookie
    view = getCookie(COOKIE_NAME) || '';
  }

  if (!view) return;

  var match = document.querySelector('.bp-section[data-branch="' + view + '"]');
  if (match) match.classList.add('bp-active');
})();
</script>

